{
  "name": "@rlynjb/aptkit-core",
  "version": "0.4.1",
  "type": "module",
  "description": "Standalone AptKit core bundle for extracted agent capabilities.",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rlynjb/aptkit.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "README.md",
    "dist/src"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "@aptkit/agent-anomaly-monitoring": "0.0.0",
    "@aptkit/agent-diagnostic-investigation": "0.0.0",
    "@aptkit/agent-query": "0.0.0",
    "@aptkit/agent-rag-query": "0.0.0",
    "@aptkit/agent-recommendation": "0.0.0",
    "@aptkit/agent-rubric-improvement": "0.0.0",
    "@aptkit/context": "0.0.0",
    "@aptkit/evals": "0.0.0",
    "@aptkit/prompts": "0.0.0",
    "@aptkit/provider-gemma": "0.0.0",
    "@aptkit/provider-local": "0.0.0",
    "@aptkit/retrieval": "0.0.0",
    "@aptkit/runtime": "0.0.0",
    "@aptkit/tools": "0.0.0",
    "@aptkit/workflows": "0.0.0"
  },
  "bundledDependencies": [
    "@aptkit/agent-anomaly-monitoring",
    "@aptkit/agent-diagnostic-investigation",
    "@aptkit/agent-query",
    "@aptkit/agent-rag-query",
    "@aptkit/agent-recommendation",
    "@aptkit/agent-rubric-improvement",
    "@aptkit/context",
    "@aptkit/evals",
    "@aptkit/prompts",
    "@aptkit/provider-gemma",
    "@aptkit/provider-local",
    "@aptkit/retrieval",
    "@aptkit/runtime",
    "@aptkit/tools",
    "@aptkit/workflows"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}
