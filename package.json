{
  "name": "aptkit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/agents/*",
    "packages/providers/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:core:deps": "npm run build -w @aptkit/runtime && npm run build -w @aptkit/tools && npm run build -w @aptkit/context && npm run build -w @aptkit/prompts && npm run build -w @aptkit/evals && npm run build -w @aptkit/workflows && npm run build -w @aptkit/agent-anomaly-monitoring && npm run build -w @aptkit/agent-diagnostic-investigation && npm run build -w @aptkit/agent-query && npm run build -w @aptkit/agent-recommendation",
    "build:core": "npm run build:core:deps && npm run build -w @rlynjb/aptkit-core",
    "dev:studio": "npm run dev -w @aptkit/studio",
    "preeval:replays": "npm run build -w @aptkit/evals",
    "eval:replays": "node scripts/eval-replay-artifacts.mjs",
    "pack:core": "node scripts/pack-core-standalone.mjs",
    "prepromote:replay": "npm run build -w @aptkit/evals",
    "promote:replay": "node scripts/promote-replay-to-fixture.mjs",
    "prereplay:model": "npm run build --workspaces --if-present",
    "replay:model": "node scripts/replay-model-recommendation.mjs",
    "prereplay:openai": "npm run build --workspaces --if-present",
    "replay:openai": "node scripts/replay-model-recommendation.mjs --provider openai",
    "test": "npm run test --workspaces --if-present",
    "prepublish:core:npm": "npm run build:core && npm run pack:core",
    "publish:core:npm": "npm publish /private/tmp/aptkit-packs/rlynjb-aptkit-core-0.3.0.tgz --access public",
    "replay:recommendation": "npm run replay:fixture -w @aptkit/agent-recommendation",
    "replay:monitoring": "npm run replay:fixture -w @aptkit/agent-anomaly-monitoring",
    "replay:monitoring:promoted": "npm run replay:promoted -w @aptkit/agent-anomaly-monitoring",
    "replay:diagnostic": "npm run replay:fixture -w @aptkit/agent-diagnostic-investigation",
    "replay:diagnostic:promoted": "npm run replay:promoted -w @aptkit/agent-diagnostic-investigation",
    "replay:query": "npm run replay:fixture -w @aptkit/agent-query",
    "replay:query:promoted": "npm run replay:promoted -w @aptkit/agent-query"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
